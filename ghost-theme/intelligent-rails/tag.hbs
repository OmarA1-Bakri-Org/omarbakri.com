{{!< default}}

<div class="ir-container">
    <header class="ir-archive-header">
        <p class="ir-archive-label">Topic</p>
        <h1 class="ir-archive-title">{{name}}</h1>
        {{#if description}}
        <p class="ir-archive-description">{{description}}</p>
        {{/if}}
    </header>

    <section class="ir-post-feed">
        {{#foreach posts}}
            {{> post-card}}
        {{/foreach}}
    </section>

    {{#if pagination.pages}}
    <nav class="ir-pagination" aria-label="Pagination">
        {{#if pagination.prev}}
        <a href="{{pagination.prev}}" class="ir-pagination-link ir-pagination-prev">&larr; Newer</a>
        {{/if}}
        <span class="ir-pagination-count">Page {{pagination.page}} of {{pagination.pages}}</span>
        {{#if pagination.next}}
        <a href="{{pagination.next}}" class="ir-pagination-link ir-pagination-next">Older &rarr;</a>
        {{/if}}
    </nav>
    {{/if}}
</div>
