<article class="ir-card {{post_class}}">
    {{#if feature_image}}
    <a href="{{url}}" class="ir-card-image" aria-hidden="true" tabindex="-1">
        <img
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w"
            sizes="(max-width: 600px) 300px, (max-width: 1000px) 600px, 1000px"
            src="{{img_url feature_image size="m"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="lazy"
        >
    </a>
    {{/if}}

    <div class="ir-card-content">
        {{#if primary_tag}}
        <a href="{{primary_tag.url}}" class="ir-card-tag">{{primary_tag.name}}</a>
        {{/if}}

        <h2 class="ir-card-title">
            <a href="{{url}}">{{title}}</a>
        </h2>

        {{#if custom_excerpt}}
        <p class="ir-card-excerpt">{{custom_excerpt}}</p>
        {{else}}
        <p class="ir-card-excerpt">{{excerpt words="30"}}</p>
        {{/if}}

        <div class="ir-card-meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMM YYYY"}}</time>
            {{#if @custom.show_reading_time}}
            <span class="ir-card-meta-sep">&middot;</span>
            <span>{{reading_time}}</span>
            {{/if}}
            {{#if featured}}
            <span class="ir-card-featured">Featured</span>
            {{/if}}
        </div>
    </div>
</article>
